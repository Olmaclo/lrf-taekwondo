APP_NAME=Sotaemad
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lrftaekwondo.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ────────────────────────────────────────────────────────────────
# Use MySQL in production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sotaemad
DB_USERNAME=sotaemad
DB_PASSWORD=

# SQLite for local dev / CI:
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sotaemad.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── PDF ──────────────────────────────────────────────────────────────────────
# DomPDF options (set by barryvdh/laravel-dompdf)
DOMPDF_PAPER_SIZE=A4
DOMPDF_IS_REMOTE_ENABLED=false

VITE_APP_NAME="${APP_NAME}"
